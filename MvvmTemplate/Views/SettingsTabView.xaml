<UserControl
    x:Class="MvvmTemplate.Views.SettingsTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:MvvmTemplate.ViewModels"
    xmlns:v="clr-namespace:MvvmTemplate.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Name="TabContent">
        <TabControl TabStripPlacement="Left" SelectedIndex="1">
            <TabItem x:Name="AccountSettingsPage">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon
                            Kind="AccountSettings"
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0" />
                        <TextBlock
                            Text="Account"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>