<UserControl
    x:Class="MvvmTemplate.Views.AccountSettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:MvvmTemplate.ViewModels"
    xmlns:v="clr-namespace:MvvmTemplate.Views">
    <Grid Name="TabContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Username -->
        <TextBlock Text="Username" VerticalAlignment="Center"/>
        <TextBox Grid.Column="1"
                Margin="5"
                Text="{Binding Username.Value, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Password -->
        <TextBlock Grid.Row="1"
                Text="Password"
                VerticalAlignment="Center"/>
        <PasswordBox Name="Password"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    PasswordChanged="PasswordChangedHandler" />

        <!-- Confirm Password -->
        <TextBlock Grid.Row="2"
                Text="Confirm Password"
                VerticalAlignment="Center"/>
        <PasswordBox Name="ConfirmPassword" 
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="5"
                    PasswordChanged="ConfirmPasswordChangedHandler" />

        <!-- Save Button -->
        <Button Grid.Row="3"
                Grid.ColumnSpan="2"
                Content="Save"
                Margin="5"
                Height="30"
                Command="{Binding SaveCommand}" />
    </Grid>
</UserControl>